{
  "name": "qr-guard-browser",
  "version": "0.1.0",
  "description": "QR Guard Browser desktop app shell.",
  "productName": "QR Guard Browser",
  "main": ".vite/build/main.js",
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "electron-forge start",
    "build:e2e": "vite build --config vite.main.config.ts && vite build --config vite.preload.config.ts && vite build --config vite.qr-preload.config.ts && vite build --config vite.renderer.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:e2e": "npm run build:e2e && playwright test",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.74.1",
    "@fluentui/react-icons": "^2.0.330",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.2",
    "@electron-forge/maker-dmg": "7.11.2",
    "@electron-forge/maker-squirrel": "7.11.2",
    "@electron-forge/maker-zip": "7.11.2",
    "@electron-forge/plugin-vite": "7.11.2",
    "@electron-forge/shared-types": "7.11.2",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.0",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "electron": "42.4.1",
    "eslint": "10.5.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.6.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "6.4.3",
    "vitest": "3.2.6"
  }
}
